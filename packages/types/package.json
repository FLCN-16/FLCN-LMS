{
  "name": "@flcn-lms/types",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "format": "prettier --ignore-path ../../.prettierignore --config ../../prettier.config.mjs --write ."
  },
  "exports": {
    "./*": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "src/*"
      ]
    }
  },
  "devDependencies": {
    "@flcn-lms/prettier-config": "workspace:*",
    "@flcn-lms/typescript-config": "workspace:*",
    "prettier": "^3.8.1",
    "typescript": "^5.7.3"
  }
}
