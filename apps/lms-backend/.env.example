# Server Configuration
PORT=8080
GIN_MODE=debug

# Database Configuration
# Option 1: Individual database parameters (will build DATABASE_URL from these)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=lms_db

# Option 2: Or use a complete DATABASE_URL (overrides DB_* parameters above)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lms_db?sslmode=disable

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-12345
JWT_EXPIRATION=24h

# License Configuration (REQUIRED)
# LICENSE_KEY is the unique license key for this LMS instance
# Must be obtained from the license server
LICENSE_KEY=your-license-key-here

# LICENSE_API_URL is the endpoint where license verification happens
# This should point to your license verification service
LICENSE_API_URL=https://api.example.com

# License Caching
LICENSE_CACHE_TTL=24h
LICENSE_VERIFY_INTERVAL=24h

# LiveKit Configuration (Optional - for live sessions)
LIVEKIT_URL=https://livekit.example.com
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_SECRET=your-livekit-secret

# Application Configuration
APP_NAME=LMS
