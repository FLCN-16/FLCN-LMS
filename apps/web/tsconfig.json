{
  "extends": "@flcn-lms/typescript-config/nextjs.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./*"],
      "@flcn-lms/ui/*": ["../../packages/ui/src/*"],
      "@flcn-lms/types": ["../../packages/types/src/index.ts"],
      "@flcn-lms/types/*": ["../../packages/types/src/*"],
      "@/i18n/*": ["./i18n/*"],
    },
    "plugins": [
      {
        "name": "next",
      },
    ],
  },
  "include": [
    "next-env.d.ts",
    "next.config.ts",
    "global.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
  ],
  "exclude": ["node_modules"],
}
